<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- SAF URIs and per-device staging files are device-local; excluding them
             also excludes orphan recovery state that wouldn't make sense on another device. -->
        <exclude domain="file" path="staging/" />
        <exclude domain="file" path="pending/" />
        <exclude domain="database" />
        <exclude domain="sharedpref" path="settings.preferences_pb" />
        <exclude domain="sharedpref" path="bundle_counter.preferences_pb" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="file" path="staging/" />
        <exclude domain="file" path="pending/" />
    </device-transfer>
</data-extraction-rules>
